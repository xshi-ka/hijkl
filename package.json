{
  "name": "xshi-kotoba",
  "version": "1.0.1",
  "description": "Xshi njajal tok",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.xshi.kotoba",
    "productName": "Xshi Kotoba",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "style.css",
      "script.js",
      "main.js"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  }



}
